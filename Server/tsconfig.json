{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "outDir": "./dist"
  },
  "include": [
    "./src/**/*",
    "./routes/**/*",
    "./models/**/*",
    "./middleware/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
